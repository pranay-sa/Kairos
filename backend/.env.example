# Groq (chat completions)
GROQ_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_CHAT_MODEL=llama-3.1-8b-instant

# Local embeddings (no key required)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Qdrant (docker-compose defaults)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kairos_documents

# Neo4j (must match docker-compose NEO4J_AUTH user/pass)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kairos-neo4j-pass

# Retrieval / grounding
CONFIDENCE_THRESHOLD=0.45
VECTOR_TOP_K=8

# GitHub PR automation (optional)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# Webhooks (optional verification)
SLACK_SIGNING_SECRET=
JIRA_WEBHOOK_SECRET=

# Azure Monitor / Log Analytics -> Qdrant (optional)
# Create an App Registration + Client Secret; grant it Log Analytics Reader on the workspace.
AZURE_MONITOR_ENABLED=false
AZURE_POLL_INTERVAL_MINUTES=20
AZURE_STATE_PATH=data/azure_monitor_state.json

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

AZURE_LOG_ANALYTICS_WORKSPACE_ID=
AZURE_LOG_ANALYTICS_ENDPOINT=https://api.loganalytics.io
# Your KQL. Keep it time-agnostic; the poller passes a timespan window.
AZURE_LOG_ANALYTICS_QUERY=AppTraces | project TimeGenerated, SeverityLevel, Message
